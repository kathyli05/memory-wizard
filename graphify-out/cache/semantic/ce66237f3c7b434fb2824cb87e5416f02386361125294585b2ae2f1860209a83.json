{"nodes": [{"id": "_claude_skills_graphify_skill_graphify_pipeline", "label": "Graphify Knowledge Graph Pipeline", "file_type": "concept", "rationale": "Turns any folder of code/docs/papers/images/video into a persistent, queryable knowledge graph with an honest EXTRACTED/INFERRED/AMBIGUOUS audit trail; community detection surfaces cross-document connections the user would not think to ask about.", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_ast_extraction", "label": "Structural AST Extraction", "file_type": "concept", "rationale": "Deterministic and free: code is extracted structurally with no LLM and no API key, so a code-only corpus needs no semantic pass at all.", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_semantic_extraction", "label": "Semantic Extraction via Parallel Subagents", "file_type": "concept", "rationale": "Docs/papers/images need LLM judgment; parallel general-purpose subagents (or Gemini if a key is set) are 5-10x faster than reading files one-by-one in the main session.", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_extraction_cache", "label": "Semantic Extraction Cache", "file_type": "concept", "rationale": "Checked before dispatching subagents so unchanged files never pay LLM cost twice; stale cache sidecars are deleted rather than merged (#1392).", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_community_detection", "label": "Community Detection and Labeling", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_god_nodes", "label": "God Nodes", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_graph_health_check", "label": "Graph Health Check", "file_type": "concept", "rationale": "Read-only integrity gate before labeling: surfaces edge collapse, dangling/missing endpoints, and self-loops \u2014 the silent-corruption modes of incremental updates and AST/LLM id mismatches. Never aborts, but warnings must be surfaced.", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_honesty_rules", "label": "Graphify Honesty Rules", "file_type": "rationale", "rationale": "Never invent an edge, never hide cohesion scores, always show token cost \u2014 the audit trail is only useful if it is honest.", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_query_fast_path", "label": "Query Fast Path", "file_type": "concept", "rationale": "When graphify-out/graph.json already exists and the request is a natural-language question, skip the whole build pipeline and query immediately \u2014 the graph is already built.", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_shrink_guard", "label": "Graph Shrink Guard (#479)", "file_type": "concept", "rationale": "to_json refuses to write a graph smaller than t