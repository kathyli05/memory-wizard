{"nodes": [{"id": "project_personal_triage_agent", "label": "Personal Triage Agent", "file_type": "concept", "rationale": "Built to manage ADHD-related friction around responsiveness and information overload while demonstrating Socially Responsible Computing: how does an agent make judgment calls on someone's behalf without being useless (too conservative) or paternalistic (silently deciding for them)?", "source_file": "PROJECT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_privacy_by_design", "label": "Privacy-by-Design Principles", "file_type": "rationale", "rationale": "Privacy-by-design, data minimization, user autonomy, and transparency govern both intake channels consistently; ambiguous decisions are flagged rather than silently chosen.", "source_file": "PROJECT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_messages_channel", "label": "Messages Triage Channel", "file_type": "concept", "source_file": "PROJECT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_screenshots_channel", "label": "Screenshot Organizer Channel", "file_type": "concept", "source_file": "PROJECT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_contact_profiles", "label": "Contact Profiles (Derived Signals)", "file_type": "concept", "rationale": "Per-thread median response latency, 90-day message frequency, and initiation ratio stored as derived signals only \u2014 never raw content.", "source_file": "PROJECT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_unanswered_detection", "label": "Unanswered Thread Detection", "file_type": "concept", "rationale": "Deterministic, no AI: last message is_from_me=0 and older than a configurable threshold (default 24h) \u2014 keeps the cheap filtering stage out of the LLM.", "source_file": "PROJECT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_triage_agent_call", "label": "Per-Thread Triage Agent Call", "file_type": "concept", "rationale": "One Claude API call per candidate thread with contact profile + last 5 messages only; structured output of urgency, reasoning, and suggest_nudge (model claude-sonnet-4-6).", "source_file": "PROJECT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_screenshot_categorization", "label": "Screenshot Vision Categorization", "file_type": "concept", "rationale": "Each image goes through one Claude vision call producing category, extracted_text, description, tags, and a nullable expires_at; only derived metadata is stored, never full-res duplicates.", "source_file": "PROJECT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_nl_search", "label": "Natural Language Screenshot Search", "file_type": "concept", "source_file": "PROJECT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_expiry_surfacing", "label": "Expiry Surfacing", "file_type": "concept", "source_file": "PROJECT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_deletion_suggestions", "label": "Screenshot Deletion Suggestions", "file_type": "concept", "rationale": "Applies to screenshots/junk only \u2014 deliberately not extended to the general photo library (people/trips/memories) because that is too emotionally high-stakes for an automated suggestion pattern; never auto-deletes.", "source_file": "PROJECT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_feedback_loop", "label": "Accept/Reject Feedback Loop", "file_type": "concept", "rationale": "Past accept/reject rates per category are pulled and included as context so Claude calibrates future suggestions \u2014 explicitly prompt-conditioning on aggregated history, NOT model fine-tuning.", "source_file": "PROJECT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "project_no_draft_scope", "label": "No Draft-Generation Scope Limit", "file_type": "rationale", "rationale": "Drafting replies on someone's behalf reads as impersonal and disrespectful to the relationship; triage surfaces urgency and reasoning, the user writes their own replies.", "source_file": "PROJECT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "project_personal_triage_agent", "target": "project_messages_channel", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "PROJECT.md", "source_location": null, "weight": 1.0}, {"source": "project_personal_triage_agent", "target": "project_screenshots_channel", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "PROJECT.md", "source_location": null, "weight": 1.0}, {"source": "project_privacy_by_design", "target": "project_personal_triage_agent", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "PROJECT.md", "source_location": null, "weight": 1.0}, {"source": "project_privacy_by_design", "target": "claude_source_immutability", "relation": "rationale_for", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "PROJECT.md", "source_location": null, "weight": 1.0}, {"source": "project_privacy_by_design", "target": "claude_api_minimization", "relation": "rationale_for", "confidence": "INFERRED", "confidence_score": 0.95, "so