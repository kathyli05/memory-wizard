{"nodes": [{"id": "claude_triage_system", "label": "Personal Information Triage System", "file_type": "concept", "rationale": "Stuff enters the user's life faster than they can process it; the system externalizes the organizing-and-judgment layer without removing the user's agency over final decisions.", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_graphify_section", "label": "CLAUDE.md graphify Section", "file_type": "document", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_source_immutability", "label": "Source Data Immutability Constraint", "file_type": "rationale", "rationale": "The source Messages database (chat.db and sidecars) and Photos library are immutable with no exceptions; all access is copy-then-read and all mutation happens only in the local triage.db. This rule outranks every other instruction and every prompt.", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_no_auto_send", "label": "Never Auto-Send Messages", "file_type": "rationale", "rationale": "Draft generation only, on explicit per-thread request; the user always copies and sends manually, preserving autonomy over communication.", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_api_minimization", "label": "API Context Minimization", "file_type": "rationale", "rationale": "Triage calls get contact profile + last 5 messages only, never full history \u2014 data minimization toward the Claude API.", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_show_reasoning", "label": "Always Show Reasoning", "file_type": "rationale", "rationale": "Every triage/deletion-suggestion result carries a human-readable rationale string, not just a score \u2014 a transparency requirement, not a nice-to-have.", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_retention_policy", "label": "Retention Policy (14-Day Raw Content Deletion)", "file_type": "concept", "rationale": "Raw message text and screenshot content are deleted from the local DB after the configured retention period; only derived signals persist past that window.", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_dashboard_review", "label": "Dashboard-Only Deletion Review", "file_type": "rationale", "rationale": "No automatic deletion from the Photos library in v1 \u2014 the user acts on suggestions manually, keeping the human in the loop.", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_vertical_slices", "label": "Vertical Slices Working Style", "file_type": "rationale", "rationale": "Get one thread or one screenshot flowing end-to-end before widening scope \u2014 surfaces integration problems early instead of at the end; plan before implementing, show evidence not assertions, checkpoint schemas before writing.", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_triage_db", "label": "Local Triage DB (./data/triage.db)", "file_type": "concept", "rationale": "The only mutable store in the system: SQLite holding derived signals only, downstream of the immutable sources.", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_streamlit_dashboard", "labe